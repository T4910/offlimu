PORT=7774
DATABASE_URL=postgres://offlimu:offlimu@localhost:5432/offlimu_sync
SERVER_NODE_ID=server-gateway
# Optional 32-byte base64 seed. If omitted, a deterministic dev seed is used.
SERVER_PRIVATE_KEY_SEED_BASE64=
OPENING_GRANT_MINOR_UNITS=5000
WEB_SEARCH_PROVIDER=mock
# Set WEB_SEARCH_PROVIDER=google and provide both values below to use Google Programmable Search JSON API.
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
WEB_SEARCH_MAX_RESULTS=3
WEB_SCRAPE_TIMEOUT_MS=8000
WEB_SCRAPE_MAX_BYTES=1000000
WEB_SCRAPER_USER_AGENT=OffLiMU-SyncServer/0.1 (+https://offlimu.local)
